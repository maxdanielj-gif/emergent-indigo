{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist-server",
    "strict": false,
    "noEmit": false
  },
  "include": ["server.ts"],
  "exclude": ["node_modules", "dist"]
}
